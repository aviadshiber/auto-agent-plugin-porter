#!/usr/bin/env bash
#
# pre-commit hook — Validates and tests marketplace before every commit.
#
# Checks:
# 1. Blocks commits directly on main/master
# 2. Runs full marketplace validation (personal paths, versions, drift, etc.)
# 3. Runs JSON validation (schema + cross-file consistency)
# 4. Runs plugin tests (frontmatter, shell syntax, shellcheck, links, plugin.json)
# 5. Enforces SKILL.md 500-line limit
#
# Install: git config core.hooksPath .githooks
#   (or run: ./scripts/setup.sh)
#
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PLUGINS_DIR="$REPO_ROOT/plugins"

red()   { printf '\033[31m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }

# ── Block commits on protected branches ──────────────────────
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
if [[ "$BRANCH" == "main" || "$BRANCH" == "master" ]]; then
    red "ERROR: Direct commits to '$BRANCH' are not allowed."
    red "Create a feature branch first:"
    echo ""
    echo "  git checkout -b feat/<description>"
    echo "  git commit ..."
    echo ""
    exit 1
fi

# ── Only validate if plugin-related files are staged ─────────
# On initial commit (no HEAD), always validate. Otherwise check staged files.
if git rev-parse --verify HEAD >/dev/null 2>&1; then
    STAGED=$(git diff --cached --name-only HEAD)
    if ! echo "$STAGED" | grep -qE '^(plugins/|\.claude-plugin/|\.agents/|registry/|scripts/|CLAUDE\.md|AGENTS\.md)'; then
        exit 0
    fi
fi

# ── Run full marketplace validation ──────────────────────────
# validate.sh runs check-instructions-sync and generate-manifests.py --check
# internally (sections 12 and 13). It prints contextual restore instructions
# on failure.
echo "Running marketplace validation..."
if ! "$REPO_ROOT/scripts/validate.sh"; then
    red ""
    red "Commit blocked — fix validation errors above."
    red "(includes CLAUDE.md → AGENTS.md pointer + registry/manifest drift checks)"
    exit 1
fi

# ── Run JSON validation ────────────────────────────────────────
echo ""
echo "Running JSON validation..."
if ! "$REPO_ROOT/scripts/validate-json.sh"; then
    red ""
    red "Commit blocked — fix JSON validation errors above."
    exit 1
fi

# ── Run plugin tests ─────────────────────────────────────────
echo ""
echo "Running plugin tests..."
if ! "$REPO_ROOT/scripts/test.sh"; then
    red ""
    red "Commit blocked — fix test failures above."
    exit 1
fi

# ── SKILL.md line count check ────────────────────────────────
# Canonical layout: plugins/<name>/skills/<name>/SKILL.md
OVER_LIMIT=0
for skill in "$PLUGINS_DIR"/*/skills/*/SKILL.md; do
    [ -f "$skill" ] || continue
    lines=$(wc -l < "$skill" | tr -d ' ')
    if [ "$lines" -gt 500 ]; then
        skill_name=$(basename "$(dirname "$skill")")
        plugin=$(basename "$(dirname "$(dirname "$(dirname "$skill")")")")
        red "ERROR: $plugin/skills/$skill_name/SKILL.md is $lines lines (max 500)"
        OVER_LIMIT=1
    fi
done

if [ "$OVER_LIMIT" -eq 1 ]; then
    red ""
    red "Move content to references/ to reduce SKILL.md line count."
    exit 1
fi

green ""
green "All pre-commit checks passed."
