#!/usr/bin/env bash
#
# pre-push hook — Blocks direct pushes to main/master and force pushes.
#
set -euo pipefail

red() { printf '\033[31m%s\033[0m\n' "$*"; }

PROTECTED_BRANCHES="^(main|master)$"

# ── Block force push ─────────────────────────────────────────
# Check if any force-push flags are in the parent git push command.
PARENT_CMD=$(ps -o args= -p $PPID 2>/dev/null || true)
if echo "$PARENT_CMD" | grep -qE -- '--force|--force-with-lease|-f '; then
    red "ERROR: Force push is forbidden in this repository."
    red "If you need to update a branch, use a new commit instead."
    exit 1
fi

# ── Block pushes to protected branches ───────────────────────
while read -r local_ref local_oid remote_ref remote_oid; do
    remote_branch="${remote_ref##refs/heads/}"
    if [[ "$remote_branch" =~ $PROTECTED_BRANCHES ]]; then
        red "ERROR: Direct push to '$remote_branch' is blocked."
        red "Create a feature branch and submit a PR instead:"
        echo ""
        echo "  git checkout -b feat/<description>"
        echo "  git push -u origin feat/<description>"
        echo ""
        exit 1
    fi
done

exit 0
