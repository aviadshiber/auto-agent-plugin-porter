{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plugin Marketplace Registry",
  "description": "Schema for registry/plugins.json — the sole source of truth for the dual-format (Claude Code + Codex CLI) marketplace.",
  "type": "object",
  "required": ["marketplace", "plugins"],
  "additionalProperties": false,
  "properties": {
    "marketplace": {
      "type": "object",
      "required": ["name", "owner", "description", "version", "pluginRoot"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "owner": {
          "type": "object",
          "required": ["name", "email"],
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "email": {"type": "string", "format": "email"}
          }
        },
        "description": {
          "type": "string",
          "minLength": 20,
          "maxLength": 1024
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "pluginRoot": {
          "type": "string",
          "pattern": "^\\./"
        }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/plugin"}
    }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "required": ["name", "version", "description", "category", "keywords", "owners"],
      "additionalProperties": false,
      "not": {
        "description": "A plugin cannot target neither agent — claude_only and codex_only are mutually exclusive.",
        "required": ["claude_only", "codex_only"],
        "properties": {
          "claude_only": {"const": true},
          "codex_only": {"const": true}
        }
      },
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "description": {
          "type": "string",
          "minLength": 20,
          "maxLength": 1536
        },
        "category": {
          "enum": [
            "documentation",
            "debugging",
            "devops",
            "analytics",
            "testing",
            "monitoring",
            "development"
          ]
        },
        "keywords": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "owners": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "claude_only": {"type": "boolean"},
        "codex_only": {"type": "boolean"},
        "lspServers": {"$ref": "#/$defs/lspServers"},
        "manifest_description": {
          "type": "string",
          "minLength": 20,
          "maxLength": 1024
        },
        "manifest_lspServers": {"$ref": "#/$defs/lspServers"},
        "manifest_unicode": {"type": "boolean"}
      }
    },
    "lspServers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["command"],
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "args": {"type": "array", "items": {"type": "string"}},
          "extensionToLanguage": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "startupTimeout": {"type": "integer", "minimum": 0},
          "restartOnCrash": {"type": "boolean"},
          "maxRestarts": {"type": "integer", "minimum": 0}
        }
      }
    }
  }
}
